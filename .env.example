# Copy this file to .env and adjust values for your machine.
DATA_DIR=data
DOCUMENT_DIR=data/documents
SPREADSHEET_DIR=data/spreadsheets
STORAGE_DIR=storage
DOCUMENT_INDEX_PATH=storage/document_index.json
DOCUMENT_MANIFEST_PATH=storage/document_manifest.json
AUDIT_LOG_PATH=storage/audit.jsonl
DEFAULT_SQLITE_PATH=data/test_analytics.db

MAX_SQL_ROWS=500
MAX_DOCUMENT_CHUNKS=8
MIN_PDF_TEXT_CHARS_PER_PAGE=40

# LLM_PROVIDER can be "ollama" or "openai".
LLM_PROVIDER=ollama
OPENAI_MODEL=gpt-5.4-mini
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_URL=http://127.0.0.1:11434

# Docker containers cannot use 127.0.0.1 to reach Ollama on your Windows host.
DOCKER_OLLAMA_URL=http://host.docker.internal:11434
LLM_MAX_OUTPUT_TOKENS=900

# OPENAI_API_KEY=sk-...
